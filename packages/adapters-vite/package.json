{
  "name": "@openzeppelin/adapters-vite",
  "version": "2.0.0",
  "private": false,
  "description": "Shared Vite and Vitest integration helpers for OpenZeppelin adapter packages",
  "keywords": [
    "openzeppelin",
    "vite",
    "vitest",
    "adapter",
    "tooling"
  ],
  "author": "Aleksandr Pasevin <aleksandr.pasevin@openzeppelin.com>",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenZeppelin/openzeppelin-adapters.git",
    "directory": "packages/adapters-vite"
  },
  "bugs": {
    "url": "https://github.com/OpenZeppelin/openzeppelin-adapters/issues"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@openzeppelin/adapter-evm": "^2.0.0",
    "@openzeppelin/adapter-midnight": "^2.0.0",
    "@openzeppelin/adapter-polkadot": "^2.0.0",
    "@openzeppelin/adapter-solana": "^2.0.0",
    "@openzeppelin/adapter-stellar": "^2.0.0",
    "vite": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "@openzeppelin/adapter-evm": {
      "optional": true
    },
    "@openzeppelin/adapter-midnight": {
      "optional": true
    },
    "@openzeppelin/adapter-polkadot": {
      "optional": true
    },
    "@openzeppelin/adapter-solana": {
      "optional": true
    },
    "@openzeppelin/adapter-stellar": {
      "optional": true
    }
  },
  "devDependencies": {
    "@openzeppelin/adapter-evm": "workspace:*",
    "@openzeppelin/adapter-midnight": "workspace:*",
    "@openzeppelin/adapter-polkadot": "workspace:*",
    "@openzeppelin/adapter-solana": "workspace:*",
    "@openzeppelin/adapter-stellar": "workspace:*",
    "eslint": "^9.32.0",
    "typescript": "^5.9.2",
    "vite": "^7.2.2",
    "vitest": "^3.2.4"
  },
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.mts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  }
}
