  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenZeppelin/openzeppelin-adapters.git",
    "directory": "packages/adapter-solana"
  },
  "bugs": {
    "url": "https://github.com/OpenZeppelin/openzeppelin-adapters/issues"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:adapters": "node ../../lint-adapters.cjs",
    "prepublishOnly": "[ \"$SKIP_PUBLISH_BUILD\" = \"true\" ] || pnpm build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
