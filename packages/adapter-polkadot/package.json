{
  "name": "@openzeppelin/adapter-polkadot",
  "version": "1.1.0",
  "private": false,
  "description": "Polkadot Adapter for UI Builder",
  "keywords": [
    "openzeppelin",
    "transaction",
    "form",
    "builder",
    "adapter",
    "polkadot",
    "substrate",
    "wagmi"
  ],
  "author": "Aleksandr Pasevin <aleksandr.pasevin@openzeppelin.com>",
  "homepage": "https://github.com/OpenZeppelin/openzeppelin-adapters#readme",
  "license": "AGPL-3.0",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "type": "module",
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenZeppelin/openzeppelin-adapters.git",
    "directory": "packages/adapter-polkadot"
  },
  "bugs": {
    "url": "https://github.com/OpenZeppelin/openzeppelin-adapters/issues"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:adapters": "node ../../lint-adapters.cjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@openzeppelin/relayer-sdk": "1.9.0",
    "@wagmi/connectors": "5.7.13",
    "@wagmi/core": "^2.20.3",
    "@web3icons/react": "^4.0.19",
    "lodash-es": "^4.17.23",
    "viem": "^2.33.3",
    "wagmi": "^2.16.1"
  },
  "devDependencies": {
    "@openzeppelin/adapter-evm-core": "workspace:*",
    "@openzeppelin/ui-types": "^1.12.0",
    "@openzeppelin/ui-utils": "^1.4.0",
    "@rainbow-me/rainbowkit": "^2.2.8",
    "@tanstack/react-query": "^5.84.1",
    "@types/lodash-es": "^4.17.12",
    "eslint": "^9.32.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "@openzeppelin/ui-types": "^1.12.0",
    "@openzeppelin/ui-utils": "^1.4.0",
    "@rainbow-me/rainbowkit": "^2.2.8",
    "@tanstack/react-query": "^5.74.7",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "viem": "^2.28.0",
    "wagmi": "^2.15.0"
  },
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.mts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./metadata": {
      "types": {
        "import": "./dist/metadata.d.mts",
        "require": "./dist/metadata.d.cts"
      },
      "import": "./dist/metadata.mjs",
      "require": "./dist/metadata.cjs"
    },
    "./networks": {
      "types": {
        "import": "./dist/networks.d.mts",
        "require": "./dist/networks.d.cts"
      },
      "import": "./dist/networks.mjs",
      "require": "./dist/networks.cjs"
    },
    "./vite-config": {
      "types": {
        "import": "./dist/vite-config.d.mts",
        "require": "./dist/vite-config.d.cts"
      },
      "import": "./dist/vite-config.mjs",
      "require": "./dist/vite-config.cjs"
    }
  }
}
