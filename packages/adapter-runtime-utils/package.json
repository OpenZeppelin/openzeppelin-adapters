{
  "name": "@openzeppelin/adapter-runtime-utils",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "description": "Internal runtime lifecycle utilities for OpenZeppelin adapters",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": "./src/index.ts",
    "./conformance": "./src/conformance/index.ts",
    "./conformance/vitest": "./src/conformance/vitest-binding.ts"
  },
  "files": [
    "src"
  ],
  "peerDependencies": {
    "@openzeppelin/ui-types": "^3.2.0",
    "vitest": "^4.1.0"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    }
  },
  "devDependencies": {
    "@openzeppelin/ui-types": "^3.2.0",
    "@types/node": "^25.0.0",
    "typescript": "^5.9.2",
    "vitest": "^4.1.0"
  }
}
