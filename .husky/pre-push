#!/usr/bin/env bash
set -e

echo "🔍 Running pre-push checks..."

# Try to use NVM's Node.js if available
if [ -s "$HOME/.nvm/nvm.sh" ]; then
  export NVM_DIR="$HOME/.nvm"
  \. "$NVM_DIR/nvm.sh"
  nvm use 20 >/dev/null 2>&1 || true
  echo "✅ Using Node.js $(node -v) from NVM"
fi

# Require Node.js 20+
node_version=$(node -v | cut -d. -f1 | sed 's/v//')
if [ "$node_version" -lt 20 ]; then
  echo "❌ Error: Node.js version $(node -v) is incompatible. This project requires Node.js 20+."
  echo "❌ Push aborted. Please use Node.js 20+ for development."
  exit 1
fi

pnpm fix-all
pnpm typecheck
pnpm test

echo "✅ All checks passed!"
