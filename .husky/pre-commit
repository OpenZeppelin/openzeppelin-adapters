#!/usr/bin/env bash
set -e

echo "🔍 Running pre-commit checks..."

# Try to use NVM's Node.js if available
if [ -s "$HOME/.nvm/nvm.sh" ]; then
  export NVM_DIR="$HOME/.nvm"
  \. "$NVM_DIR/nvm.sh"
  nvm use 22 >/dev/null 2>&1 || true
  echo "✅ Using Node.js $(node -v) from NVM"
fi

# Require Node.js >= 22.13.0 (pnpm@11 requires Node.js >= 22.13)
node_major=$(node -v | cut -d. -f1 | sed 's/v//')
node_minor=$(node -v | cut -d. -f2)
if [ "$node_major" -lt 22 ] || { [ "$node_major" -eq 22 ] && [ "$node_minor" -lt 13 ]; }; then
  echo "❌ Error: Node.js version $(node -v) is incompatible. This project requires Node.js >= 22.13.0."
  echo "❌ Commit aborted. Please use Node.js >= 22.13.0 for development."
  exit 1
fi

# Check if there are any staged files
staged_files=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -z "$staged_files" ]; then
  echo "ℹ️ No files staged for commit, skipping checks."
  exit 0
fi

echo "🎨 Running formatting and linting..."
pnpm exec lint-staged
